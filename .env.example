# 계이득(ideukgae) 릴레이 사이트 — 환경변수 (api/ 코드가 실제로 읽는 이름만)
# 값은 여기에 쓰지 않는다 — Vercel 프로젝트 env에만 설정 (DEPLOY-RELAY-P0.md §3).

# Supabase — 프로그램 사이트와 같은 기존 프로젝트 공유 (auth.users 공유가 전제)
SUPABASE_URL=
# 서버 함수 전용 — 절대 클라이언트/로그 노출 금지
SUPABASE_SERVICE_ROLE_KEY=
# 브라우저용 공개 키 (api/site-config.ts가 클라이언트에 전달)
# 코드 폴백 이름: SUPABASE_PUBLISHABLE_KEY / NEXT_PUBLIC_SUPABASE_ANON_KEY /
# VITE_SUPABASE_ANON_KEY / PUBLIC_SUPABASE_ANON_KEY —
# 정본 이름 SUPABASE_ANON_KEY 하나만 설정
SUPABASE_ANON_KEY=

# 비밀번호 재설정 메일 착지 URL — https://<사이트>/login 으로 설정
# (api/auth-password-reset.ts — 미설정 시 코드 기본값이 구 프로그램 사이트로 향한다
#  — 새 프로젝트에서는 사실상 필수)
BBBB_PASSWORD_RESET_REDIRECT_URL=

# 정본 오리진 (api/channel-page.ts OG 절대 URL) — 도메인 확정 후 설정.
# 비어 있으면 SSR이 요청 호스트(x-forwarded-host)에서 오리진을 유도한다 —
# *.vercel.app 스모크 단계에서는 비워 둬도 된다.
SITE_ORIGIN=

# (선택) api/site-config.ts가 읽음 — 기본값 wobuzhi6322/BBBB, 릴레이 페이지는 미사용
GITHUB_REPO=
