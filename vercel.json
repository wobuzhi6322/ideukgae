{
  "rewrites": [
    { "source": "/@:handle/d/:messageId", "destination": "/api/channel-page?handle=:handle&messageId=:messageId" },
    { "source": "/@:handle", "destination": "/api/channel-page?handle=:handle" },
    { "source": "/me/:section", "destination": "/me.html" },
    { "source": "/me", "destination": "/me.html" },
    { "source": "/studio/:section", "destination": "/studio.html" },
    { "source": "/studio", "destination": "/studio.html" },
    { "source": "/channels", "destination": "/channels.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/signup", "destination": "/signup.html" }
  ],
  "functions": {
    "api/channel-page.ts": {
      "includeFiles": "public/channel.html"
    }
  }
}
